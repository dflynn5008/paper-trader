# Get paper keys from: https://app.alpaca.markets/paper/dashboard/overview
ALPACA_API_KEY=your_paper_api_key
ALPACA_SECRET_KEY=your_paper_secret_key

# Paper trading only — keep this true until you deliberately go live
ALPACA_PAPER=true

# Comma-separated watchlist (liquid names that work with small dollar amounts)
SYMBOLS=F,SOFI,PLTR,AMD,QQQ

# Virtual portfolio: treat the bot as if you only have this much capital
STARTING_CAPITAL=100
TRADE_NOTIONAL_USD=25
MAX_POSITIONS=2
MAX_DAILY_ORDERS=3
MAX_DRAWDOWN_PCT=20

# Crypto (24/7) — separate virtual portfolio
CRYPTO_SYMBOLS=BTC/USD,ETH/USD,SOL/USD
CRYPTO_STARTING_CAPITAL=100
CRYPTO_TRADE_NOTIONAL_USD=25
CRYPTO_MAX_POSITIONS=2
CRYPTO_MAX_DAILY_ORDERS=12
CRYPTO_MAX_DRAWDOWN_PCT=20

# Discord phone alerts (optional)
# Create a webhook in a private server channel, then paste the URL here.
DISCORD_WEBHOOK_URL=
# Set true to also alert on buy/sell signals, even when blocked
DISCORD_ALERT_SIGNALS=false
